# Copie este arquivo para .streamlit/secrets.toml e preencha com os valores reais.
# NUNCA suba secrets.toml para o GitHub (adicione ao .gitignore).

# Connection string do Neon.tech (PostgreSQL Serverless)
# Formato: postgresql://usuario:senha@ep-xxxxx.region.aws.neon.tech/nomedobanco?sslmode=require
NEON_CONN_STRING = "postgresql://usuario:senha@ep-xxxxx.us-east-2.aws.neon.tech/krt_telemetria?sslmode=require"

# Senha única compartilhada da equipe para acesso ao dashboard (Tela 1)
APP_PASSWORD = "troque-esta-senha"
